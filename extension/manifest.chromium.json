{
  "manifest_version": 3,
  "name": "Meta.ai Omnibox",
  "short_name": "@meta",
  "description": "Type @meta in the omnibox to open Meta.ai with a new prompt.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.meta.ai/*", "https://meta.ai/*"],
  "icons": {
    "16": "icons/icon64.png",
    "32": "icons/icon64.png",
    "48": "icons/icon64.png",
    "64": "icons/icon64.png",
    "128": "icons/icon64.png"
  },
  "omnibox": {
    "keyword": "@meta"
  },
  "chrome_settings_overrides": {
    "search_provider": {
      "name": "Meta.ai",
      "keyword": "@meta",
      "search_url": "https://www.meta.ai/?extensionPrompt={searchTerms}",
      "encoding": "UTF-8",
      "favicon_url": "icons/icon64.png",
      "is_default": false
    }
  },
  "action": {
    "default_title": "Open Meta.ai",
    "default_icon": {
      "16": "icons/icon64.png",
      "32": "icons/icon64.png",
      "48": "icons/icon64.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.meta.ai/*", "https://meta.ai/*"],
      "js": ["content/meta-inject.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "minimum_chrome_version": "110"
}
