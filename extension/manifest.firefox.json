{
  "manifest_version": 3,
  "name": "Meta (Unofficial)",
  "short_name": "Meta",
  "description": "Unofficial extension — not affiliated with Meta. Use @Meta in the address bar or the registered search engine to open meta.ai with your prompt.",
  "version": "0.1.3",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.meta.ai/*", "https://meta.ai/*"],
  "icons": {
    "16": "icons/icon64.png",
    "32": "icons/icon64.png",
    "48": "icons/icon64.png",
    "64": "icons/icon64.png",
    "128": "icons/icon64.png"
  },
  "omnibox": {
    "keyword": "@Meta"
  },
  "chrome_settings_overrides": {
    "search_provider": {
      "name": "Meta (Unofficial)",
      "keyword": "@Meta",
      "search_url": "https://www.meta.ai/?prompt={searchTerms}",
      "encoding": "UTF-8",
      "favicon_url": "icons/icon64.png",
      "is_default": false
    }
  },
  "action": {
    "default_title": "Meta (Unofficial) — open meta.ai",
    "default_icon": {
      "16": "icons/icon64.png",
      "32": "icons/icon64.png",
      "48": "icons/icon64.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.meta.ai/*", "https://meta.ai/*"],
      "js": ["content/meta-inject.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "meta-ai-omnibox@vocino.github.io",
      "strict_min_version": "121.0"
    }
  }
}
